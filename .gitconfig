[user]
	name = Adriano Bacha
	email = abacha@gmail.com
[color]
	ui = auto
[github]
	user = abacha
	token = $GITHUB_TOKEN
[merge]
  tool = nvim
[diff]
  tool = nvim -d
[dude]
	interval = 60
[alias]
  a = add
  amend = commit --amend --no-edit
  ap = add --patch
  b = branch
  ci = commit -m
  co = checkout
  dc = diff --cached
  di = diff
  fp = fetch --prune
  h = log --graph --pretty='format:%C(yellow)%h%Cblue%d%Creset %s %C(white) %an, %ar%Creset' --all --date=relative
  l = log --pretty=\"format:%C(yellow)%h%Cblue%d%Creset %s %C(white) %an, %ar%Creset\" --all
  rb = rebase
  rbm = rebase origin/master
  s = status -s
  st = status
  pop = stash pop
  sq = rebase HEAD~20 -i --autosquash
	fixup-first = "!f(){ base=\"$(git symbolic-ref --quiet --short refs/remotes/origin/HEAD 2>/dev/null | sed 's#^origin/##')\"; if [ -z \"$base\" ]; then if git show-ref --verify --quiet refs/remotes/origin/main; then base=main; else base=master; fi; fi; target=$(git rev-list --reverse --grep='^fixup! ' --grep='^squash! ' --invert-grep HEAD ^origin/$base | head -n 1); if [ -n \"$target\" ]; then git commit --fixup=$target; else echo 'Nenhum commit base encontrado na branch.'; fi; }; f"
[push]
	default = matching
[branch]
	autosetuprebase = always
[rebase]
  autosquash = true
[pull]
	rebase = true
[core]
	excludesfile = /home/abacha/.gitignore
