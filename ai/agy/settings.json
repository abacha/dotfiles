{
  "general": {
    "preferredEditor": "neovim",
    "vimMode": true,
    "previewFeatures": false,
    "enablePromptCompletion": true,
    "enableNotifications": true,
    "plan": {
      "directory": "~/.openclaw/workspace/specs/"
    }
  },
  "permissions": {
    "allow": [
      "Read",
      "Glob",
      "Grep",
      "Edit",
      "Write",
      "MultiEdit",
      "Bash(ls:*)",
      "Bash(cd:*)",
      "Bash(cat:*)",
      "Bash(pwd:*)",
      "Bash(echo:*)",
      "Bash(grep:*)",
      "Bash(tree:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(npm info:*)",
      "Bash(npm run dev:*)"
    ],
    "ask": [
      "Bash"
    ]
  },
  "security": {
    "auth": {
      "selectedType": "agy-api-key"
    },
    "folderTrust": {
      "enabled": true
    }
  },
  "ui": {
    "theme": "GitHub",
    "footer": {
      "hideContextPercentage": false
    },
    "dynamicWindowTitle": true,
    "showStatusInTitle": true,
    "showUserIdentity": false,
    "useAlternateBuffer": false,
    "hideTips": true
  },
  "output": {
    "format": "text"
  },
  "tools": {
    "shell": {
      "showColor": true
    }
  },
  "ide": {
    "enabled": true
  },
  "hooks": {
    "BeforeTool": [
      {
        "matcher": "run_shell_command",
        "hooks": [
          {
            "type": "command",
            "command": "/home/abacha/.agy/hooks/rtk-hook-agy.sh"
          }
        ]
      }
    ]
  }
}