#!/bin/bash
# ai-usage-tracker.sh
# A shell script for tracking Claude Code and OpenAI Codex usage.
# - Fetches the 5-hour and 7-day windows directly from Anthropic's OAuth API.
# - Safely refreshes Claude's OAuth token by invoking the CLI directly.
# - Parses ~/.codex/auth.json for OpenAI.
#
# Requires: curl, jq, date

set -e

CACHE_TTL=300 # 5 minutes
COMMAND_TIMEOUT=${AI_USAGE_TRACKER_COMMAND_TIMEOUT:-20}
CURL_MAX_TIME=${AI_USAGE_TRACKER_CURL_MAX_TIME:-15}

run_with_timeout() {
    if command -v timeout >/dev/null 2>&1; then
        timeout "$COMMAND_TIMEOUT" "$@"
    else
        "$@"
    fi
}

# Make common user-level CLI locations available even in non-login shells.
export PATH="$HOME/.local/bin:$HOME/.asdf/shims:$HOME/.asdf/bin:$PATH"

FRESH=0
ONLY_CLAUDE=0
ONLY_CODEX=0
IS_REAL_RUN=0

for arg in "$@"; do
    case $arg in
        --fresh) FRESH=1 ;;
        --claude) ONLY_CLAUDE=1 ;;
        --codex) ONLY_CODEX=1 ;;
        --real-run) IS_REAL_RUN=1 ;;
    esac
done

if [ "$ONLY_CLAUDE" = "0" ] && [ "$ONLY_CODEX" = "0" ]; then
    ONLY_CLAUDE=1
    ONLY_CODEX=1
fi

CACHE_PREFIX="ai-usage-tracker"
if [ "$ONLY_CLAUDE" = "1" ] && [ "$ONLY_CODEX" = "0" ]; then CACHE_PREFIX="ai-usage-tracker-claude"; fi
if [ "$ONLY_CODEX" = "1" ] && [ "$ONLY_CLAUDE" = "0" ]; then CACHE_PREFIX="ai-usage-tracker-codex"; fi
CACHE_FILE="/tmp/${CACHE_PREFIX}-cache.txt"

should_cache_output() {
    local output_file="$1"

    if [ ! -f "$output_file" ]; then
        return 1
    fi

    if grep -Eq 'API Error: .*rate limited|API Error: .*Rate limited|rate limited|Too Many Requests|Could not fetch usage limits|No OAuth access token found|Failed to get a valid OAuth access token' "$output_file"; then
        return 1
    fi

    return 0
}

render_dynamic_times() {
    local file="$1"
    local now
    now=$(date +%s)
    awk -v now="$now" '
    {
        while (match($0, /\{RES_IN_TS:[0-9]+\}/)) {
            ts_str = substr($0, RSTART+11, RLENGTH-12)
            ts = ts_str + 0
            diff = ts - now
            if (diff < 0) diff = 0

            days = int(diff / 86400)
            hours = int((diff % 86400) / 3600)
            mins = int((diff % 3600) / 60)

            if (days > 0)
                res = days "d " hours "h"
            else if (hours > 0)
                res = hours "h " mins "m"
            else if (mins > 0)
                res = mins "m"
            else
                res = "now"

            $0 = substr($0, 1, RSTART-1) res substr($0, RSTART+RLENGTH)
        }
        print $0
    }
    ' "$file"
}

if [ "$IS_REAL_RUN" = "0" ]; then
    if [ "$FRESH" = "1" ]; then
        rm -f "$CACHE_FILE"
    elif [ -f "$CACHE_FILE" ]; then
        NOW=$(date +%s)
        if [[ "$OSTYPE" == "darwin"* ]]; then
            CACHE_MOD=$(stat -f "%m" "$CACHE_FILE" 2>/dev/null || echo 0)
        else
            CACHE_MOD=$(stat -c "%Y" "$CACHE_FILE" 2>/dev/null || echo 0)
        fi
        AGE=$((NOW - CACHE_MOD))
        if [ "$AGE" -ge 0 ] && [ "$AGE" -lt "$CACHE_TTL" ]; then
            render_dynamic_times "$CACHE_FILE"
            echo ""
            echo "💡 (Cached ${AGE}s ago. Run with --fresh to bypass)"
            exit 0
        fi
    fi

    TMP_OUTPUT=$(mktemp)
    set +e
    run_with_timeout "$0" "$@" --real-run > "$TMP_OUTPUT" 2>&1
    RUN_STATUS=$?
    set -e

    if [ "$RUN_STATUS" -eq 124 ]; then
        echo "⏱️ ai-usage-tracker timed out after ${COMMAND_TIMEOUT}s; showing last cached successful output if available." >> "$TMP_OUTPUT"
    fi

    if should_cache_output "$TMP_OUTPUT"; then
        render_dynamic_times "$TMP_OUTPUT"
        mv "$TMP_OUTPUT" "$CACHE_FILE"
    else
        if [ -f "$CACHE_FILE" ]; then
            render_dynamic_times "$CACHE_FILE"
        else
            render_dynamic_times "$TMP_OUTPUT"
        fi
        rm -f "$TMP_OUTPUT"
    fi

    exit $RUN_STATUS
fi

draw_bar() {
    local pct=${1:-0}
    local filled=$((pct / 10))
    local empty=$((10 - filled))
    local bar=""
    for ((i=0; i<filled; i++)); do bar+="█"; done
    for ((i=0; i<empty; i++)); do bar+="░"; done
    echo "$bar"
}

status_emoji() {
    local pct=${1:-0}
    if [ "$pct" -gt 80 ]; then
        echo "🔴"
    elif [ "$pct" -gt 50 ]; then
        echo "🟡"
    else
        echo "🟢"
    fi
}

format_date_and_time() {
    local dt="$1"
    if [ -z "$dt" ] || [ "$dt" = "null" ] || [ "$dt" = "N/A" ]; then
        echo "unknown"
        return
    fi
    if ! command -v date >/dev/null 2>&1; then
        echo "unknown"
        return
    fi

    local ts=0
    if [[ "$OSTYPE" == "darwin"* ]]; then
        local clean_dt="${dt%Z}"
        ts=$(date -j -f "%Y-%m-%dT%H:%M:%S" "$clean_dt" +%s 2>/dev/null || echo 0)
    else
        ts=$(date -d "$dt" +%s 2>/dev/null || echo 0)
    fi

    if [ "$ts" -le 0 ]; then
        echo "unknown"
        return
    fi

    echo "{RES_IN_TS:${ts}}"
}

format_iso_timestamp_local() {
    local ts="$1"
    if [ -z "$ts" ] || [ "$ts" = "null" ]; then
        echo "unknown"
        return
    fi
    if ! command -v date >/dev/null 2>&1; then
        echo "$ts"
        return
    fi

    local sanitized="$ts"
    if [[ "$sanitized" == *.*Z ]]; then
        sanitized="${sanitized%%.*}Z"
    fi

    local formatted
    if [[ "$OSTYPE" == "darwin"* ]]; then
        formatted=$(date -j -f "%Y-%m-%dT%H:%M:%SZ" "$sanitized" "+%Y-%m-%d %H:%M:%S %Z" 2>/dev/null ||                    date -j -f "%Y-%m-%dT%H:%M:%S%z" "$sanitized" "+%Y-%m-%d %H:%M:%S %Z" 2>/dev/null || echo "$ts")
    else
        formatted=$(date -d "$ts" "+%Y-%m-%d %H:%M:%S %Z" 2>/dev/null || echo "$ts")
    fi

    echo "$formatted"
}

format_tokens_short() {
    local value="$1"
    if [ -z "$value" ] || [ "$value" = "null" ]; then
        echo "0"
        return
    fi
    awk -v val="$value" 'BEGIN {
        if (val >= 1e9) { printf "%.1fB", val / 1e9 }
        else if (val >= 1e6) { printf "%.1fM", val / 1e6 }
        else if (val >= 1e3) { printf "%.1fk", val / 1e3 }
        else { printf "%.0f", val }
    }'
}

format_cost_value() {
    local value="$1"
    if [ -z "$value" ] || [ "$value" = "null" ]; then
        echo ""
        return
    fi
    printf "%.2f" "$value"
}

check_claude_auth() {
    local creds_file="$1"
    local label="$2"
    local is_active="${3:-1}"
    local profile_id="${4:-default}"

    local profile_cache="/tmp/ai-usage-tracker-claude-${profile_id}.cache"

    if [ "$is_active" = "0" ]; then
        if [ -f "$profile_cache" ]; then
            local cache_mod
            if [[ "$OSTYPE" == "darwin"* ]]; then
                cache_mod=$(stat -f "%Sm" -t "%Y-%m-%d %H:%M:%S" "$profile_cache" 2>/dev/null || echo "unknown")
            else
                cache_mod=$(stat -c "%y" "$profile_cache" 2>/dev/null | cut -d. -f1 || echo "unknown")
            fi
            local display_label="${label#⏸ }"
            display_label="${display_label#▶ }"
            awk -v repl="   [⏸ ${display_label}] (cached at ${cache_mod})" '
                BEGIN { done = 0 }
                {
                    if (!done && $0 ~ /^   \[▶[[:space:]]/ ) {
                        print repl
                        done = 1
                        next
                    }
                    gsub(/\[▶/, "[⏸")
                    print
                }
            ' "$profile_cache"
        fi
        return
    fi

    if [ "$FRESH" = "1" ]; then
        rm -f "$profile_cache"
    fi

    TMP_OUTPUT=$(mktemp)
    do_check_claude_auth "$creds_file" "$label" > "$TMP_OUTPUT"
    cat "$TMP_OUTPUT"
    if should_cache_output "$TMP_OUTPUT"; then
        mv "$TMP_OUTPUT" "$profile_cache"
    else
        rm -f "$TMP_OUTPUT"
    fi
}

do_check_claude_auth() {
    local creds_file="$1"
    local label="$2"

    if [ ! -f "$creds_file" ]; then return; fi

    local access_token
    local expires_at

    access_token=$(jq -r '.claudeAiOauth.accessToken // empty' "$creds_file")
    expires_at=$(jq -r '.claudeAiOauth.expiresAt // empty' "$creds_file")

    if [ -n "$label" ]; then
        echo "   [$label]"
    fi

    if [ -n "$access_token" ] && [ "$access_token" != "null" ]; then
        local now_ms
        now_ms=$(($(date +%s) * 1000))

        if [ -n "$expires_at" ] && [ "$now_ms" -gt "$((expires_at - 60000))" ]; then
            local temp_swap=0
            if [ "$creds_file" != "$HOME/.claude/.credentials.json" ]; then
                cp "$creds_file" "$HOME/.claude/.credentials.json.tmp_tracker" 2>/dev/null || true
                cp "$HOME/.claude/.credentials.json" "$HOME/.claude/.credentials.json.backup_tracker" 2>/dev/null || true
                cp "$creds_file" "$HOME/.claude/.credentials.json" 2>/dev/null || true
                temp_swap=1
            fi

            export PATH=/home/abacha/.asdf/installs/nodejs/25.7.0/bin:$PATH
            if command -v claude >/dev/null 2>&1; then
                echo "2+2" | run_with_timeout claude >/dev/null 2>&1 || true
                # Re-read token
                access_token=$(jq -r '.claudeAiOauth.accessToken // empty' "$HOME/.claude/.credentials.json")
                if [ "$temp_swap" -eq 1 ]; then
                    cp "$HOME/.claude/.credentials.json" "$creds_file" 2>/dev/null || true
                fi
            else
                echo "   ❌ OAuth token expired and 'claude' CLI not found. Cannot auto-refresh."
            fi

            if [ "$temp_swap" -eq 1 ]; then
                mv "$HOME/.claude/.credentials.json.backup_tracker" "$HOME/.claude/.credentials.json" 2>/dev/null || true
                rm -f "$HOME/.claude/.credentials.json.tmp_tracker" 2>/dev/null || true
            fi
        fi

        if [ -z "$access_token" ] || [ "$access_token" = "null" ]; then
            echo "   ❌ Failed to get a valid OAuth access token."
            return
        fi

        local usage
        usage=$(curl -s --connect-timeout 5 --max-time "$CURL_MAX_TIME" -H "Authorization: Bearer $access_token" \
            -H "anthropic-beta: oauth-2025-04-20" \
            https://api.anthropic.com/api/oauth/usage)

        local error_msg
        error_msg=$(echo "$usage" | jq -r '.error.message // empty')
        if [ -n "$error_msg" ]; then
            echo "   ❌ API Error: $error_msg"
            if echo "$error_msg" | grep -q "user:profile"; then
                echo "   💡 Tip: Your token lacks the 'user:profile' scope. Generate a new token or run 'claude login'."
            elif echo "$error_msg" | grep -q "expired"; then
                echo "   💡 Tip: Your OAuth token has expired. Run 'claude login' to get a fresh token."
            fi
        else
            local five_pct
            five_pct=$(echo "$usage" | jq -r '.five_hour.utilization // 0' | cut -d. -f1)
            local five_reset
            five_reset=$(echo "$usage" | jq -r '.five_hour.resets_at // "N/A"')
            local week_pct
            week_pct=$(echo "$usage" | jq -r '.seven_day.utilization // 0' | cut -d. -f1)
            local week_reset
            week_reset=$(echo "$usage" | jq -r '.seven_day.resets_at // "N/A"')

            [ "$five_pct" = "null" ] && five_pct=0
            [ "$week_pct" = "null" ] && week_pct=0

            if [ "$week_pct" -ge 100 ]; then
                five_pct=100
                five_reset="$week_reset"
            fi

            local five_left
            five_left=$(format_date_and_time "$five_reset")
            local week_left
            week_left=$(format_date_and_time "$week_reset")

            printf "   ⏱️  %-15s %s %s %3d%%  (Resets in: %s)\n" "Session (5h):" "$(status_emoji "$five_pct")" "$(draw_bar "$five_pct")" "$five_pct" "$five_left"
            printf "   📅  %-15s %s %s %3d%%  (Resets in: %s)\n" "Weekly (7d):" "$(status_emoji "$week_pct")" "$(draw_bar "$week_pct")" "$week_pct" "$week_left"
        fi
    else
        echo "   ❌ No OAuth access token found."
    fi
}

if [ "$ONLY_CLAUDE" = "1" ]; then
echo "=== 🦞 Claude Code (OAuth) ==="

if [ -f "$HOME/.claude/.credentials-hs.json" ] || [ -f "$HOME/.claude/.credentials-p.json" ]; then
    ACTIVE_CLAUDE=$(cat "$HOME/.claude/.active-profile" 2>/dev/null || echo "unknown")
    if [ "$ACTIVE_CLAUDE" = "hs" ]; then
        check_claude_auth "$HOME/.claude/.credentials.json" "▶ Hubstaff" 1 "hs"
        echo ""
        check_claude_auth "$HOME/.claude/.credentials-p.json" "⏸ Personal" 0 "p"
    elif [ "$ACTIVE_CLAUDE" = "p" ]; then
        check_claude_auth "$HOME/.claude/.credentials.json" "▶ Personal" 1 "p"
        echo ""
        check_claude_auth "$HOME/.claude/.credentials-hs.json" "⏸ Hubstaff" 0 "hs"
    else
        if [ -f "$HOME/.claude/.credentials-hs.json" ]; then
            check_claude_auth "$HOME/.claude/.credentials-hs.json" "Hubstaff" 1 "hs"
            echo ""
        fi
        if [ -f "$HOME/.claude/.credentials-p.json" ]; then
            check_claude_auth "$HOME/.claude/.credentials-p.json" "Personal" 1 "p"
        fi
    fi
else
    if [ -n "$CLAUDE_CODE_OAUTH_TOKEN" ]; then
        ACCESS_TOKEN="$CLAUDE_CODE_OAUTH_TOKEN"
        USAGE=$(curl -s --connect-timeout 5 --max-time "$CURL_MAX_TIME" -H "Authorization: Bearer $ACCESS_TOKEN" \
            -H "anthropic-beta: oauth-2025-04-20" \
            https://api.anthropic.com/api/oauth/usage)

        ERROR_MSG=$(echo "$USAGE" | jq -r '.error.message // empty')
        if [ -n "$ERROR_MSG" ]; then
            echo "   ❌ API Error: $ERROR_MSG"
        else
            FIVE_PCT=$(echo "$USAGE" | jq -r '.five_hour.utilization // 0' | cut -d. -f1)
            FIVE_RESET=$(echo "$USAGE" | jq -r '.five_hour.resets_at // "N/A"')
            WEEK_PCT=$(echo "$USAGE" | jq -r '.seven_day.utilization // 0' | cut -d. -f1)
            WEEK_RESET=$(echo "$USAGE" | jq -r '.seven_day.resets_at // "N/A"')

            [ "$FIVE_PCT" = "null" ] && FIVE_PCT=0
            [ "$WEEK_PCT" = "null" ] && WEEK_PCT=0

            if [ "$WEEK_PCT" -ge 100 ]; then
                FIVE_PCT=100
                FIVE_RESET="$WEEK_RESET"
            fi

            FIVE_LEFT=$(format_date_and_time "$FIVE_RESET")
            WEEK_LEFT=$(format_date_and_time "$WEEK_RESET")

            printf "   ⏱️  %-15s %s %s %3d%%  (Resets in: %s)\n" "Session (5h):" "$(status_emoji $FIVE_PCT)" "$(draw_bar $FIVE_PCT)" "$FIVE_PCT" "$FIVE_LEFT"
            printf "   📅  %-15s %s %s %3d%%  (Resets in: %s)\n" "Weekly (7d):" "$(status_emoji $WEEK_PCT)" "$(draw_bar $WEEK_PCT)" "$WEEK_PCT" "$WEEK_LEFT"
        fi
    else
        CREDS_FILE="$HOME/.claude/.credentials.json"
        if [ ! -f "$CREDS_FILE" ]; then
            echo "❌ No credentials found at $CREDS_FILE"
        else
            check_claude_auth "$CREDS_FILE" "Active"
        fi
    fi
fi
echo ""
fi

