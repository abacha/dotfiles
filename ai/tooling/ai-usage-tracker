    local auth_file="$1"
    local label="$2"
    local is_active="${3:-1}"
    local profile_id="${4:-default}"

    local profile_cache="/tmp/ai-usage-tracker-codex-${profile_id}.cache"

    if [ "$is_active" = "0" ]; then
        if [ -f "$profile_cache" ]; then
            local cache_mod
            if [[ "$OSTYPE" == "darwin"* ]]; then
                cache_mod=$(stat -f "%Sm" -t "%Y-%m-%d %H:%M:%S" "$profile_cache" 2>/dev/null || echo "unknown")
            else
                cache_mod=$(stat -c "%y" "$profile_cache" 2>/dev/null | cut -d. -f1 || echo "unknown")
            fi
            local display_label="${label#⏸ }"
            display_label="${display_label#▶ }"
            awk -v repl="   [⏸ ${display_label}] (cached at ${cache_mod})" '
                BEGIN { done = 0 }
                {
                    if (!done && $0 ~ /^   \[▶[[:space:]]/ ) {
                        print repl
                        done = 1
                        next
                    }
                    gsub(/\[▶/, "[⏸")
                    print
                }
            ' "$profile_cache"
        fi
        return
    fi

    if [ "$FRESH" = "1" ]; then
        rm -f "$profile_cache"
    fi

    TMP_OUTPUT=$(mktemp)
    do_check_codex_auth "$auth_file" "$label" > "$TMP_OUTPUT"
