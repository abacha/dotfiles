if [ "$ONLY_CODEX" = "1" ]; then
if [ "$ONLY_CLAUDE" = "1" ]; then echo ""; fi
echo "=== 🤖 OpenAI Codex ==="

if [ -f "$HOME/.codex/auth-hs.json" ] || [ -f "$HOME/.codex/auth-p.json" ]; then
