<?xml version="1.0" ?>
<TrainingCenterDatabase xmlns="http://www.garmin.com/xmlschemas/TrainingCenterDatabase/v2" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.garmin.com/xmlschemas/TrainingCenterDatabase/v2 http://www.garmin.com/xmlschemas/TrainingCenterDatabasev2.xsd">
  <Workouts>
    <Workout Sport="Running">
      <Name>Sample_Intervals</Name>
      <Step xsi_type="Step_t">
        <StepId>1</StepId>
        <Name>Warm Up</Name>
        <Duration xsi_type="TimeMode_t">
          <Seconds>600</Seconds>
        </Duration>
        <Intensity>Active</Intensity>
        <Target xsi_type="NoneMode_t"/>
      </Step>
      <Step xsi_type="Step_t">
        <StepId>2</StepId>
        <Name>Fast Run</Name>
        <Duration xsi_type="DistanceMode_t">
          <Meters>800</Meters>
        </Duration>
        <Intensity>Active</Intensity>
        <Target xsi_type="SpeedMode_t">
          <SpeedZone xsi_type="CustomSpeedZone_t">
            <ViewAs>Pace</ViewAs>
            <LowInMetersPerSecond>3.3333333333333335</LowInMetersPerSecond>
            <HighInMetersPerSecond>4.166666666666667</HighInMetersPerSecond>
          </SpeedZone>
        </Target>
      </Step>
      <Step xsi_type="Step_t">
        <StepId>3</StepId>
        <Name>Recover</Name>
        <Duration xsi_type="TimeMode_t">
          <Seconds>90</Seconds>
        </Duration>
        <Intensity>Resting</Intensity>
        <Target xsi_type="NoneMode_t"/>
      </Step>
      <Step xsi_type="Step_t">
        <StepId>4</StepId>
        <Name>Cool Down</Name>
        <Duration xsi_type="TimeMode_t">
          <Seconds>300</Seconds>
        </Duration>
        <Intensity>Active</Intensity>
        <Target xsi_type="NoneMode_t"/>
      </Step>
    </Workout>
  </Workouts>
</TrainingCenterDatabase>
